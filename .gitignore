# Ignore everything by default.
*

# Allow public documentation and distribution folders.
!dist/
!docs/

# Allow primary documentation.
!.gitignore
!README.md
!docs/*.md
!dist/README.md

# Allow public Excel workbooks and version manifest.
!dist/*.xlsm
!dist/versions.json

# Ignore Office and temporary files.
~$*
*.tmp
*.bak
